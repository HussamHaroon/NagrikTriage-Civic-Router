# --- Gemini (AI triage) ---
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Supabase (persistence for officer / mayor dashboards) ---
# Browser-safe: these are bundled into the client. The publishable/anon key
# is constrained by Row Level Security on the database.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_key_here

# SERVER-ONLY. NEVER prefix this with NEXT_PUBLIC_.
# Never commit, never paste in chat, never ship to the browser.
# Used only in app/api/* server routes.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here